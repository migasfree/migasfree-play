{
  "name": "migasfree-play",
  "version": "5.14.0",
  "type": "module",
  "description": "Desktop graphical interface for Migasfree. Enables end-users to securely manage software catalogs, devices, and client synchronization.",
  "productName": "migasfree-play",
  "author": "Jose Antonio Chavarría <jachavar@gmail.com>",
  "license": "GPLv3",
  "copyright": "© 2017-2026 migasfree team",
  "homepage": "https://github.com/migasfree/migasfree-play",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,ts,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css,ts,cjs,mjs,html,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,vue,css,ts,cjs,mjs,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gettext:extract": "node scripts/i18n-metadata.js && vue-gettext-extract",
    "gettext:compile": "vue-gettext-compile",
    "dev": "quasar dev -m electron -- --no-sandbox --disable-gpu-sandbox",
    "build": "quasar build -m electron -- --no-sandbox --disable-gpu-sandbox",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/dosis": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@quasar/extras": "1.17.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "axios": "1.18.1",
    "compare-versions": "6.1.1",
    "dayjs": "1.11.21",
    "pinia": "3.0.4",
    "python-shell": "5.0.0",
    "qrcode.vue": "3.10.0",
    "quasar": "2.20.2",
    "util": "0.12.5",
    "vue": "3.5.39",
    "vue-router": "5.1.0",
    "vue3-gettext": "4.0.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@electron/packager": "20.0.1",
    "@pinia/testing": "1.0.3",
    "@quasar/app-vite": "2.0.5",
    "@quasar/quasar-app-extension-qmarkdown": "2.0.5",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.9",
    "@vue/compiler-sfc": "3.5.39",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/test-utils": "2.4.11",
    "autoprefixer": "10.5.2",
    "devtron": "1.4.0",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "electron-debug": "4.1.0",
    "electron-devtools-installer": "4.0.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-vue": "10.9.2",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "vite": "7.3.6",
    "vitest": "4.1.9",
    "vue-eslint-parser": "10.4.1"
  },
  "browserslist": [
    "defaults and supports es6-module"
  ],
  "engines": {
    "node": ">= 22.12.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "resolutions": {
    "@electron/get": "3.1.0"
  },
  "lint-staged": {
    "*.{js,vue,ts,cjs,mjs}": [
      "prettier --write",
      "eslint --fix",
      "vitest related --run"
    ],
    "*.{css,html,md,json}": [
      "prettier --write"
    ]
  }
}
